{
  "name": "hopnstay",
  "version": "1.0.0",
  "private": true,
  "description": "HopnStay affiliate-only hotel comparison app using Next.js, Prisma, Supabase PostgreSQL, and Travelpayouts/mock providers.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "prisma generate",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "validate:production-env": "tsx scripts/validate-production-env.ts",
    "production:validate": "npm run validate:production-env && npm run typecheck && npm test && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "dotenv": "16.4.7",
    "lucide-react": "0.468.0",
    "next": "15.5.18",
    "next-auth": "4.24.14",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.12.0",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "6.0.2",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.18",
    "jsdom": "25.0.1",
    "postcss": "8.5.10",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.22.3",
    "typescript": "5.7.2",
    "vitest": "4.1.7"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
